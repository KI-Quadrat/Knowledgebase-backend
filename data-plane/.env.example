# ── Data Plane Settings (DP_ prefix) ──────────────────
DP_HMAC_SECRET=                  # HMAC-SHA256 shared secret (empty = auth disabled)
DP_MODE=on-premise               # "on-premise" or "cloud"
DP_TENANT_ID=wiener-neudorf      # Municipality identifier
DP_WORKER_ID=wn-worker-01        # Worker node identifier
DP_ONLINE_API_KEYS=              # Comma-separated API keys for online endpoints (empty = online disabled)
DP_LOG_LEVEL=info                # debug | info | warning | error
DP_LOG_JSON=true                 # true = structured JSON logs, false = console
DP_CORS_ORIGINS=*                # Comma-separated allowed origins

# ── Jina Reader (default primary scraper) ──
# Jina is the default backend for /online/scrape (and BFS /online/crawl).
# Firecrawl is the automatic fallback; raw httpx is the final fallback.
JINA_API_URL=https://eu-r-beta.jina.ai
JINA_API_KEY=                        # Jina API key (required for the default path)

# ── Firecrawl (automatic fallback after Jina; opt-in primary via scraper="firecrawl") ──
# Now part of the default fallback chain, so set FIRECRAWL_API_KEY wherever you
# want fallback coverage. Point FIRECRAWL_API_URL at a self-hosted EU instance
# for data residency; the managed cloud has no EU region. Also used by the
# /online/crawl firecrawl map backend.
FIRECRAWL_API_URL=https://api.firecrawl.dev
FIRECRAWL_API_KEY=

# ── LlamaParse (cloud document parsing) ──────────────
# Leave LLAMA_CLOUD_API_KEY empty to use the local Unstructured parser instead.
LLAMA_CLOUD_API_KEY=
LLAMA_CLOUD_BASE_URL=https://api.cloud.llamaindex.ai/api/v1/parsing
# EU endpoint: https://api.cloud.eu.llamaindex.ai/api/v1/parsing

# ── BGE-M3 (embedding model) ─────────────────────────
BGE_M3_URL=http://bge-m3:8080
# Per-request batch cap for the self-hosted BGE-M3 server. embed_batch splits
# larger inputs into windows of this size. 0 disables splitting.
BGE_M3_MAX_BATCH=32

# ── Qdrant (vector database) ─────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=wiener-neudorf # Default collection name (tenant-based)

# ── Qdrant — AT-specific instance (POST /api/v1/online/ingest/at + DELETE /online/vectors/at/...) ──
# QDRANT_URL_AT may include the port inline (e.g. https://host:6333) or carry only
# the scheme+host with QDRANT_PORT_AT supplying the port. Leave QDRANT_PORT_AT
# unset when the port is already embedded in the URL (including the implicit 443
# for https:// URLs). When QDRANT_URL_AT is empty, the service falls back to the
# default QDRANT_URL / QDRANT_API_KEY above.
QDRANT_URL_AT=
QDRANT_PORT_AT=
QDRANT_API_KEY_AT=

# ── Redis (caching & rate limiting) ───────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenAI (default LLM provider + OpenAI embedding option) ──
# OPENAI_MODEL is also the *global default* model for the three intelligence
# tasks (classifier / contextual / funding) when their per-task overrides
# below are empty. Bare model names (no slash) are interpreted as the
# "openai" provider by app/services/intelligence/llm_router.py.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional. Set only when pointing the "openai" provider at a custom
# endpoint (Azure OpenAI, self-hosted vLLM, corporate proxy). Empty keeps
# the SDK default https://api.openai.com/v1.
OPENAI_BASE_URL=
# Per-request batch cap for OpenAI /v1/embeddings (API allows up to 2048
# inputs / ~300K tokens). embed_batch splits larger inputs into windows.
# 0 disables splitting.
OPENAI_EMBED_MAX_BATCH=256
# Per-call cap for the contextual enricher's batched chat-completion path.
# Larger inputs are split into parallel windows of this size; each window
# falls back to per-chunk independently if its batched call fails.
# 0 disables splitting (single call for all chunks).
OPENAI_CONTEXTUAL_MAX_BATCH=32

# ── Per-task LLM model routing ─────────────────────────
# Each intelligence task can pick its own model via "<provider>/<model_id>"
# (e.g. "openai/gpt-4o-mini", "nebius/Qwen/Qwen2.5-72B-Instruct"). Empty
# falls back to OPENAI_MODEL above. A bare name (no slash) is treated as
# the "openai" provider. See llm_router.py for resolution rules.
CLASSIFIER_MODEL=
CONTEXTUAL_MODEL=
FUNDING_MODEL=

# ── Additional OpenAI-compatible providers ─────────────
# Built-in providers ship with their public endpoints — only set the
# corresponding API key for each one you actually use. Override the
# base URL only when pointing at a self-hosted endpoint (vLLM, etc.).
#   nebius     → https://api.studio.nebius.ai/v1
#   together   → https://api.together.xyz/v1
#   groq       → https://api.groq.com/openai/v1
#   fireworks  → https://api.fireworks.ai/inference/v1
#   deepinfra  → https://api.deepinfra.com/v1/openai
NEBIUS_BASE_URL=
NEBIUS_API_KEY=
TOGETHER_BASE_URL=
TOGETHER_API_KEY=
GROQ_BASE_URL=
GROQ_API_KEY=
FIREWORKS_BASE_URL=
FIREWORKS_API_KEY=
DEEPINFRA_BASE_URL=
DEEPINFRA_API_KEY=

# ── TEI — BGE-M3 dense embedding endpoint (shared by /online/ingest and /online/ingest/at) ──
# OpenAI-compatible server. POST {TEI_EMBED_URL_AT}/v1/embeddings, bearer auth.
# TEI_EMBED_MODEL_AT is sent in every request — embed.ki2.at returns an empty
# 200 body when model is missing, so a valid model ID is required (not optional).
# CF-Access pair is only needed when the endpoint is behind Cloudflare Access.
TEI_EMBED_URL_AT=https://embed.ki2.at
TEI_EMBED_API_KEY_AT=
TEI_EMBED_MODEL_AT=BAAI/bge-m3
TEI_CF_ACCESS_CLIENT_ID_AT=
TEI_CF_ACCESS_CLIENT_SECRET_AT=
# Per-request cap enforced by the TEI dense server (--max-client-batch-size).
# embed_batch splits larger inputs into windows of this size. 0 disables split.
TEI_EMBED_MAX_BATCH_AT=32

# ── Sparse embedding endpoint (hybrid search) ──
# Used by every hybrid path: /online/ingest with vector_config.search_mode=hybrid,
# /api/v1/search with search_mode=hybrid, /online/vectors/sparse-encode, and any
# future AT hybrid ingest. (Currently /online/ingest/at is dense-only.)
#
# Contract: POST {SPARSE_EMBED_URL_AT}/embed_sparse with body {"texts": [...]}.
# Bearer auth via SPARSE_EMBED_API_KEY_AT, plus optional Cloudflare Access
# service-token headers (CF-Access-Client-Id / CF-Access-Client-Secret) when
# the endpoint sits behind CF Access.
# SPARSE_EMBED_MODEL_AT is unused by the request (the endpoint serves a fixed
# model) and is retained only for informational logging on /ready.
SPARSE_EMBED_URL_AT=https://sparse.ki2.at
SPARSE_EMBED_API_KEY_AT=
SPARSE_EMBED_MODEL_AT=BAAI/bge-m3
SPARSE_CF_ACCESS_CLIENT_ID_AT=
SPARSE_CF_ACCESS_CLIENT_SECRET_AT=
# Per-request cap enforced by the TEI sparse server (--max-client-batch-size).
# encode_batch splits larger inputs into windows of this size. 0 disables split.
SPARSE_EMBED_MAX_BATCH_AT=32

# ── ClickHouse (audit logging) ───────────────────────
CLICKHOUSE_REQUIRED=false        # true = fail startup if unreachable
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=ki2_audit
CLICKHOUSE_USER=dataplane
CLICKHOUSE_PASSWORD=

# ── LDAP (on-premise only) ───────────────────────────
LDAP_URL=ldap://dc.example.local
LDAP_BIND_DN=CN=ki2-service,OU=ServiceAccounts,DC=example,DC=local
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=DC=example,DC=local

# ── SMB (on-premise only) ────────────────────────────
SMB_USERNAME=ki2-service
SMB_PASSWORD=
SMB_DOMAIN=EXAMPLE

# ── Cloudflare R2 (cloud only) ───────────────────────
R2_ENDPOINT_URL=https://account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ki2-documents
